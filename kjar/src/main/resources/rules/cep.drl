package rules

import rs.moma.flightforge.model.ForecastHour;
import rs.moma.flightforge.model.ScheduledSession;
import rs.moma.flightforge.model.SessionAlert;
import rs.moma.flightforge.model.SessionAlertType;
import rs.moma.flightforge.model.HourSuitability;
import rs.moma.flightforge.model.ReminderSent;
import rs.moma.flightforge.model.CurrentTime;
import rs.moma.flightforge.model.DayPart;
import rs.moma.flightforge.model.WeatherDeteriorationDetected;

import java.time.format.DateTimeFormatter;

declare ForecastHour
    @role(event)
    @timestamp(timestamp)
end

declare ScheduledSession
    @role(event)
    @timestamp(startTimeMs)
    @duration(durationMillis)
end

declare CurrentTime
    @role(event)
    @timestamp(timestamp)
end

declare ReminderSent
    @role(event)
    @timestamp(sessionStartTime)
    @expires(48h)
end

rule "CEP.1 - Flight reminder for tomorrow's session"
    when
        $now : CurrentTime()
        $session : ScheduledSession($start : startTime, this after[12h,36h] $now)
        not ReminderSent(sessionStartTime == $start)
    then
        insert(new ReminderSent($start));
        DateTimeFormatter fmt = DateTimeFormatter.ofPattern("dd.MM.yyyy 'at' HH:mm");
        channels["alerts"].send(new SessionAlert(
            SessionAlertType.FLIGHT_REMINDER,
            "Reminder: you have a flight session scheduled tomorrow " + $start.format(fmt) + ".",
            $session,
            null
        ));
end

rule "CEP.2 - Session no longer suitable"
    when
        $session : ScheduledSession()
        $hour : ForecastHour(
            suitability == HourSuitability.UNSUITABLE,
            this during $session
        )
        not WeatherDeteriorationDetected(
            type == SessionAlertType.SESSION_NO_LONGER_SUITABLE,
            session == $session,
            hour == $hour
        )
    then
        insert(new WeatherDeteriorationDetected(SessionAlertType.SESSION_NO_LONGER_SUITABLE, $session, $hour));
end

rule "CEP.3 - Finish flight warning"
    when
        $now : CurrentTime()
        $session : ScheduledSession(this includes $now)
        $hour : ForecastHour(
            suitability == HourSuitability.UNSUITABLE,
            this after[1s,2h] $now
        )
        not WeatherDeteriorationDetected(
            type == SessionAlertType.FINISH_FLIGHT,
            session == $session,
            hour == $hour
        )
    then
        insert(new WeatherDeteriorationDetected(SessionAlertType.FINISH_FLIGHT, $session, $hour));
end

rule "CEP.4 - Expire past sessions"
    when
        $now : CurrentTime()
        $session : ScheduledSession($start : startTime, endTime before $now)
        $reminders : java.util.List() from collect(ReminderSent(sessionStartTime == $start))
        $detections : java.util.List() from collect(WeatherDeteriorationDetected(session == $session))
    then
        delete($session);
        for (Object r : $reminders) delete(r);
        for (Object d : $detections) delete(d);
end

rule "CEP.4b - Expire past forecast hours"
    when
        $now : CurrentTime()
        $hour : ForecastHour(timestamp before $now)
    then
        delete($hour);
end

rule "CEP.5 - Compose weather deterioration alert"
    when
        $detected : WeatherDeteriorationDetected($type : type, $session : session, $hour : hour)
    then
        DateTimeFormatter fmt = DateTimeFormatter.ofPattern("dd.MM.yyyy 'at' HH:mm");
        String reason = $hour.getPrecipitation() > 0.0 ? String.format("rain (%.1f mm)", $hour.getPrecipitation())
                       : $hour.getDayPart() == DayPart.NIGHT ? "nighttime"
                       : $hour.getTemperature() < 0.0 || $hour.getTemperature() > 30.0 ? String.format("extreme temperature (%.0f°C)", $hour.getTemperature())
                       : String.format("strong wind (%.1f m/s)", $hour.getWindSpeed());
        String message = $type == SessionAlertType.SESSION_NO_LONGER_SUITABLE
            ? "Session at " + $session.getStartTime().format(fmt) + " is no longer suitable: " + reason + " expected at " + $hour.getTimestamp().format(fmt) + "."
            : "Conditions deteriorating (" + reason + ") — finish your flight before " + $hour.getTimestamp().format(fmt) + ".";
        channels["alerts"].send(new SessionAlert($type, message, $session, $hour));
end
